# ── AI Provider Credentials ────────────────────────────────────────────────────
# On Replit: these are automatically injected by the AI Integrations system.
# On self-hosted / other environments: fill in your own API keys below.

# OpenAI (or any OpenAI-compatible endpoint)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Anthropic (or any Anthropic-compatible endpoint)
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# ── Proxy Authentication ────────────────────────────────────────────────────────
# This key is used to authenticate requests to the proxy.
# Set it in your client (CherryStudio, OpenAI SDK, etc.) as the API key.
PROXY_API_KEY=your-secret-key-here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Static File Serving (Docker only) ─────────────────────────────────────────
# When set, the server also serves the portal frontend from this directory.
STATIC_DIR=/app/public
